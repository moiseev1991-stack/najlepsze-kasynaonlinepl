# Plesk: document root = /httpdocs, statyczny Next leży w /httpdocs/site/
# Ten plik musi leżeć w katalogu głównym repozytorium (po deploy: httpdocs/.htaccess).
# Usuń domyślny index.html z Pleska w httpdocs (README) — nie używaj DirectoryIndex disabled,
# bo psuje index.html w podkatalogach przy document root = httpdocs/site/.

ErrorDocument 404 /site/404.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Nie serwuj kodu źródłowego z katalogu deploy
  RewriteRule ^(src|scripts|text|site\.git)(/|$) - [F,L]

  # Domyślny plik Pleska w httpdocs — serwuj statyczną stronę z site/
  RewriteRule ^index\.html$ site/index.html [L]

  # Strona główna
  RewriteRule ^$ site/index.html [L]

  # Plik istnieje w site/ (/_next/, /images/, robots.txt, itd.)
  RewriteCond %{DOCUMENT_ROOT}/site%{REQUEST_URI} -f
  RewriteRule . site%{REQUEST_URI} [L]

  # Next export: kanoniczny URL z końcowym /. Bez tego /foo → 404 (foo/index.html nie trafia w regułę poniżej).
  RewriteCond %{DOCUMENT_ROOT}/site%{REQUEST_URI} !-f
  RewriteCond %{REQUEST_URI} !/$
  RewriteCond %{DOCUMENT_ROOT}/site%{REQUEST_URI}/index.html -f
  RewriteRule ^(.*)$ /$1/ [R=301,L]

  # /ścieżka/ → site/ścieżka/index.html
  RewriteCond %{DOCUMENT_ROOT}/site%{REQUEST_URI}index.html -f
  RewriteRule . site%{REQUEST_URI}index.html [L]
</IfModule>

Options -Indexes
