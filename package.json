  "scripts": {
    "postinstall": "node scripts/build-review-editorial.mjs",
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\"",
    "dev": "npm run clean && next dev -p 3055",
    "dev:fast": "next dev -p 3055",
    "dev:127": "next dev -p 3055 -H 127.0.0.1",
